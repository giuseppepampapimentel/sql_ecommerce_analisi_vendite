      <rd:DataSourceID>d271895a-06e1-46a1-9478-d1f349fa5211</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ClientiTop">
      <Query>
        <DataSourceName>localhost</DataSourceName>
        <CommandText>SELECT 
    C.nome_cliente,
    COUNT(O.id_ordine) AS numero_ordini,
    SUM(DO.quantita * DO.prezzo_unitario) AS totale_speso,
    AVG(DO.quantita * DO.prezzo_unitario) AS media_per_ordine
FROM cliente C
LEFT JOIN ordine O ON C.id_cliente = O.id_cliente
LEFT JOIN dettaglio_ordine DO ON O.id_ordine = DO.id_ordine
GROUP BY C.nome_cliente
ORDER BY totale_speso DESC;</CommandText>
      </Query>
      <Fields>
        <Field Name="nome_cliente">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nome_cliente</DataField>
        </Field>
        <Field Name="numero_ordini">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>numero_ordini</DataField>
        </Field>
        <Field Name="totale_speso">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>totale_speso</DataField>
        </Field>
        <Field Name="media_per_ordine">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>media_per_ordine</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
